# Application
APP_NAME="Farming Assistant API"
DEBUG=false

# Database (MySQL)
DATABASE_URL=mysql+asyncmy://farmer:farmerpass@db:3306/farming_db
DATABASE_URL_SYNC=mysql+pymysql://farmer:farmerpass@db:3306/farming_db

# Security — CHANGE THIS in production!
SECRET_KEY=your-super-secret-key-change-me

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# External APIs (optional — mocked if not provided)
OPENWEATHER_API_KEY=your_openweathermap_api_key
OPENAI_API_KEY=your_openai_api_key
